# ── Translation Provider ──────────────────────────
# Options: "mock" | "google"
# "mock" returns [LANG_CODE] prefixed text for development
# "google" uses Google Cloud Translation API (requires GOOGLE_API_KEY)
TRANSLATION_PROVIDER=mock

# Google Cloud Translation API Key (only needed if TRANSLATION_PROVIDER=google)
GOOGLE_API_KEY=

# Optional extra secret mixed into message encryption key derivation.
# If set here, set the same value in client/.env as VITE_MESSAGE_ENCRYPTION_SECRET.
MESSAGE_ENCRYPTION_SECRET=

# ── Firebase (Optional) ──────────────────────────
# Leave blank to use in-memory storage (no persistence)
# Set these to enable Firestore persistence
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Server ────────────────────────────────────────
PORT=3001
